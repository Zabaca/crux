# Web UI dev: point at the repo-root `.crux.db` (the same file the CLI uses
# when run from this checkout). The path is relative to apps/web/ since that's
# the cwd when `bun run dev` runs.
#
# Override by exporting CRUX_DB_URL in your shell. Falls back to XDG default
# if neither is set, just like the CLI.
CRUX_DB_URL=file:../../.crux.db
