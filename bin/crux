#!/usr/bin/env bash
# Crux plugin entrypoint. Resolves its own plugin root, lazily installs
# Bun deps on first use, then forwards to the CLI.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PLUGIN_ROOT="$(dirname "$SCRIPT_DIR")"

if ! command -v bun >/dev/null 2>&1; then
  cat >&2 <<'MSG'
crux: bun is required and not on PATH.

Install bun:
  macOS/Linux:  curl -fsSL https://bun.sh/install | bash
  macOS (brew): brew install oven-sh/bun/bun
  Windows:      powershell -c "irm bun.sh/install.ps1|iex"

After install, restart your shell (or source the bun config) and re-run.
Docs: https://bun.sh
MSG
  exit 127
fi

if [ ! -d "$PLUGIN_ROOT/node_modules" ]; then
  (cd "$PLUGIN_ROOT" && bun install --frozen-lockfile >/dev/null 2>&1) \
    || (cd "$PLUGIN_ROOT" && bun install >/dev/null 2>&1)
fi

# Always set CRUX_HOME explicitly so Bun's .env load can't override it.
# Default: user DB at ~/.claude/.crux.
# CRUX_DEV=1 + cwd inside repo: dev DB at $PLUGIN_ROOT/.crux (opt-in).
# An already-set CRUX_HOME always wins.
if [ -z "${CRUX_HOME:-}" ]; then
  CRUX_HOME="$HOME/.claude/.crux"
  if [ "${CRUX_DEV:-0}" = "1" ] && [ -d "$PLUGIN_ROOT/.git" ]; then
    case "$PWD/" in
      "$PLUGIN_ROOT"/*|"$PLUGIN_ROOT/")
        CRUX_HOME="$PLUGIN_ROOT/.crux"
        echo "crux: dev mode — writing to $PLUGIN_ROOT/.crux (unset CRUX_DEV to disable)" >&2
        ;;
    esac
  fi
  export CRUX_HOME
fi

exec bun run "$PLUGIN_ROOT/packages/cli/src/index.ts" "$@"
