#!/usr/bin/env bash
# Crux plugin entrypoint. Resolves its own plugin root, lazily installs
# Bun deps on first use, then forwards to the CLI.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PLUGIN_ROOT="$(dirname "$SCRIPT_DIR")"

if [ ! -d "$PLUGIN_ROOT/node_modules" ]; then
  (cd "$PLUGIN_ROOT" && bun install --frozen-lockfile >/dev/null 2>&1) \
    || (cd "$PLUGIN_ROOT" && bun install >/dev/null 2>&1)
fi

# Dev-mode guard: only fire when the caller is *actively working inside* this
# plugin's git checkout — i.e. cwd is within PLUGIN_ROOT. The earlier .git-alone
# heuristic misrouted real user data whenever /path/to/cloned-crux/bin/crux
# was invoked from an unrelated cwd (see issue #2). Cwd-scoping is the concrete
# "doing dev work on crux itself" signal. CRUX_DEV=0 force-disables even when
# cwd is inside the repo. An explicit CRUX_DB_URL always wins.
if [ -z "${CRUX_DB_URL:-}" ] && [ -d "$PLUGIN_ROOT/.git" ]; then
  case "$PWD/" in
    "$PLUGIN_ROOT"/*|"$PLUGIN_ROOT/")
      if [ "${CRUX_DEV:-}" = "0" ]; then
        # Explicit opt-out: force XDG path so the committed .env doesn't silently
        # pull us back into the dev db when Bun auto-loads it.
        export CRUX_DB_URL="file:${XDG_DATA_HOME:-$HOME/.local/share}/crux/crux.db"
      else
        export CRUX_DB_URL="file:$PLUGIN_ROOT/.crux.db"
        echo "crux: dev-mode guard active — writing to $PLUGIN_ROOT/.crux.db (set CRUX_DEV=0 to disable)" >&2
      fi
      ;;
  esac
fi

exec bun run "$PLUGIN_ROOT/packages/cli/src/index.ts" "$@"
