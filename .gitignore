# Whitelist model: ignore everything noisy, let .claude through explicitly below.
node_modules/
dist/
.next/
.DS_Store

# Local libSQL database — migrations are committed, data is not.
*.db
*.db-journal
*.db-shm
*.db-wal
.crux.db*
.crux/

# Local config — .env is committed on purpose (pins dev state to repo-local
# .crux/; see the file for context). Only .env.local variants are private.
.env.local
.env.*.local

# Editor / OS noise
.vscode/
.idea/
*.log
*.tsbuildinfo

# Claude/agent noise — whitelist what's intentional, ignore the rest.
.claude/*
!.claude/skills/
.view-state.json
.env
