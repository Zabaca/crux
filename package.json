{
  "name": "crux",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*", "apps/*"],
  "scripts": {
    "migrate": "drizzle-kit migrate --config .config/drizzle.config.ts",
    "generate": "drizzle-kit generate --config .config/drizzle.config.ts",
    "seed": "bun run scripts/seed-ws-crux.ts",
    "reset": "bun run scripts/reset.ts",
    "lint": "oxlint -c .config/oxlint.json",
    "format": "bunx oxfmt .",
    "crux": "bun run packages/cli/src/index.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.0",
    "oxlint": "^0.15.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "drizzle-orm": "^0.45.2",
    "smol-toml": "^1.3.0",
    "zod": "^3.23.0"
  }
}
