# Committed on purpose. When you run `bun run migrate`, `bun run seed`, or any
# crux command from this repo's cwd, Bun auto-loads this file and CRUX_DB_URL
# points every db write at the repo-local `.crux.db`. That keeps dev work off
# your real user-level db at $XDG_DATA_HOME/crux/crux.db.
#
# Plugin consumers are unaffected: Bun reads .env from cwd, not from the plugin
# source dir, so a user running the installed plugin from their own project
# never loads this file. bin/crux also sets this explicitly in dev mode (when
# .git is present), so the guard works even if you cd into a subdir.
CRUX_DB_URL=file:.crux.db
